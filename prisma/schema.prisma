generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RiskLevel {
  BAJO
  MEDIO
  ALTO
  CRITICO
  DESCONOCIDO
}

enum HumanReviewStatus {
  PENDIENTE
  CONFIRMADA
  FALSO_POSITIVO
  REQUIERE_MAS_REVISION
  NO_REQUERIDA
  DESCONOCIDA
}

model Camera {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique @map("codigo")
  name      String   @map("nombre")
  location  String?  @map("ubicacion")
  active    Boolean  @default(true) @map("activa")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("camaras")
}

model DetectionEvent {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  object            String    @map("objeto")
  confidence        Decimal   @map("confianza") @db.Decimal(5, 4)
  risk              RiskLevel @map("riesgo")
  detectedAt        DateTime  @default(now()) @map("detected_at") @db.Timestamptz(6)
  cameraId          String    @map("camara_id")
  box               Json
  imageUrl          String?   @map("imagen_url")
  location          String?   @map("ubicacion")
  riskScore         Decimal?  @map("score_riesgo") @db.Decimal(5, 4)
  riskLevel         String?   @map("nivel_riesgo")
  action            String?   @map("accion_tomada")
  previousAlerts24h Int       @default(0) @map("alertas_previas_24h")
  dayHour           Int?      @map("hora_dia")
  reviewId          String?   @map("review_id")
  context           Json?     @map("contexto")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  humanReviews      HumanReview[]

  @@index([cameraId, detectedAt(sort: Desc)], map: "idx_detection_events_camera_detected_at")
  @@index([cameraId, riskLevel, detectedAt(sort: Desc)], map: "idx_detection_events_camera_level_detected_at")
  @@index([detectedAt(sort: Desc)], map: "idx_detection_events_detected_at")
  @@index([risk, detectedAt(sort: Desc)], map: "idx_detection_events_risk_detected_at")
  @@index([object, detectedAt(sort: Desc)], map: "idx_detection_events_object_detected_at")
  @@index([reviewId], map: "idx_detection_events_review_id")
  @@map("detection_events")
}

model HumanReview {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  detectionEventId    String?           @map("detection_event_id") @db.Uuid
  reviewId            String?           @map("review_id")
  trackingId          String?           @map("tracking_id")
  cameraId            String?           @map("camara_id")
  status              HumanReviewStatus @default(PENDIENTE) @map("estado_revision")
  humanLabel          String?           @map("human_label")
  actionFinal         String?           @map("accion_final")
  supervisorUserId    String?           @map("supervisor_user_id")
  supervisorUsername  String?           @map("supervisor_username")
  feedbackForTraining Boolean           @default(false) @map("alimentar_entrenamiento")
  rawCallback         String?           @map("raw_callback")
  context             Json?             @map("contexto")
  decidedAt           DateTime?         @map("decided_at") @db.Timestamptz(6)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  detectionEvent DetectionEvent? @relation(fields: [detectionEventId], references: [id])

  @@index([trackingId, createdAt(sort: Desc)], map: "idx_human_reviews_tracking_created_at")
  @@index([reviewId, createdAt(sort: Desc)], map: "idx_human_reviews_review_id_created_at")
  @@index([status, createdAt(sort: Desc)], map: "idx_human_reviews_status_created_at")
  @@map("human_reviews")
}
