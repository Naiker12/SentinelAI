generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RiskLevel {
  BAJO
  MEDIO
  ALTO
  DESCONOCIDO
}

model Camera {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique @map("codigo")
  name      String   @map("nombre")
  location  String?  @map("ubicacion")
  active    Boolean  @default(true) @map("activa")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("camaras")
}

model DetectionEvent {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  object     String    @map("objeto")
  confidence Decimal   @map("confianza") @db.Decimal(5, 4)
  risk       RiskLevel @map("riesgo")
  detectedAt DateTime  @default(now()) @map("detected_at") @db.Timestamptz(6)
  cameraId   String    @map("camara_id")
  box        Json
  imageUrl   String?   @map("imagen_url")
  location   String?   @map("ubicacion")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([cameraId, detectedAt(sort: Desc)], map: "idx_detection_events_camera_detected_at")
  @@index([detectedAt(sort: Desc)], map: "idx_detection_events_detected_at")
  @@index([risk, detectedAt(sort: Desc)], map: "idx_detection_events_risk_detected_at")
  @@index([object, detectedAt(sort: Desc)], map: "idx_detection_events_object_detected_at")
  @@map("detection_events")
}
